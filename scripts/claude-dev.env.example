# ============================================================
# Claude Dev Orchestration — Environment Variables
# Copy this file to ~/.claude-dev.env and fill in your values.
# Never commit the filled-in file to git.
# ============================================================

# --- Project ---
# Absolute path to your local git repository
CLAUDE_DEV_PROJECT_DIR="$HOME/projects/your-project"

# Git remote branch to base all work off of
CLAUDE_DEV_BASE_BRANCH="main"

# --- Logging ---
# Where session JSON logs and launchd output are written
CLAUDE_DEV_LOG_DIR="$HOME/claude-logs"

# --- Claude Models ---
# Orchestrator model (Opus — the decision maker)
CLAUDE_DEV_ORCHESTRATOR_MODEL="claude-opus-4-5"

# Subagent model (Sonnet — the workers)
CLAUDE_DEV_AGENT_MODEL="claude-sonnet-4-5"

# --- GitHub ---
# The GitHub repo in "owner/repo" format (used by gh CLI)
CLAUDE_DEV_GITHUB_REPO="your-github-username/your-repo"

# Label that marks issues as ready for agents to pick up
CLAUDE_DEV_LABEL_READY="ready"

# Label applied when an agent claims an issue
CLAUDE_DEV_LABEL_IN_PROGRESS="in-progress"

# Label applied when a PR has been opened by an agent
CLAUDE_DEV_LABEL_PR_OPEN="pr-open"

# Label applied when an agent is blocked and needs human help
CLAUDE_DEV_LABEL_BLOCKED="blocked"

# --- Retry Limits ---
# How many times the implementer/tester can cycle before giving up
CLAUDE_DEV_MAX_FIX_CYCLES=3

# How many times the reviewer can cycle before giving up
CLAUDE_DEV_MAX_REVIEW_CYCLES=2

# --- Schedule (used for documentation only — set in the plist) ---
# These are not read by scripts directly; they're here so your
# plist values are documented alongside everything else.
# Format: 24h hour and minute
CLAUDE_DEV_SCHEDULE_1_HOUR=8
CLAUDE_DEV_SCHEDULE_1_MINUTE=0
CLAUDE_DEV_SCHEDULE_2_HOUR=13
CLAUDE_DEV_SCHEDULE_2_MINUTE=0
