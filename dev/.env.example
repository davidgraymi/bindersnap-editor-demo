# Copy this file to dev/.env and fill in values after first docker compose up.
# The seed script prints ALICE_TOKEN to stdout on first run.

VITE_GITEA_URL=http://localhost:3000
VITE_GITEA_TOKEN=
VITE_HOCUSPOCUS_URL=ws://localhost:1234
APP_PORT=5173

# Dev-only UI auto-login (handled server-side by src/index.ts).
# Defaults to true in development and is forced to false by bun run test:integration.
BUN_PUBLIC_DEV_AUTO_LOGIN=true
VITE_DEV_AUTO_LOGIN=true
BINDERSNAP_DEV_AUTO_LOGIN=true
GITEA_INTERNAL_URL=http://gitea:3000
GITEA_ADMIN_USER=alice
GITEA_ADMIN_PASS=bindersnap-dev

# Stripe — get from Stripe dashboard (leave empty in dev)
# Payment Link: Dashboard > Payment Links > Create
# Customer Portal: Dashboard > Settings > Billing > Customer portal
BUN_PUBLIC_STRIPE_PAYMENT_LINK=
BUN_PUBLIC_STRIPE_PORTAL_URL=
# Server-side webhook secret — from Stripe CLI: stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=
