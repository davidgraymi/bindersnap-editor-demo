{
  "name": "bindersnap-editor-demo",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run clean && bun build ./apps/landing/index.html --outdir=dist --target=browser --minify --splitting --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "clean": "rm -rf dist",
    "dev": "bun --hot server.ts",
    "down": "docker compose -f dev/docker-compose.yml down -v",
    "lighthouse": "bun run build && sh -c 'python3 -m http.server 4173 --directory dist >/dev/null 2>&1 & SERVER_PID=$!; sleep 1; bunx lighthouse http://localhost:4173 --output=json --output-path=./lighthouse.json --quiet --chrome-flags=\"--headless --no-sandbox --disable-gpu\" --no-enable-error-reporting; kill $SERVER_PID' && bun run summarize",
    "start": "NODE_ENV=production bun server.ts",
    "summarize": "bun scripts/summarize-lighthouse.ts",
    "test:integration": "bash scripts/test-integration.sh",
    "up": "docker compose -f dev/docker-compose.yml up --build"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.5",
    "@tiptap/extension-color": "^3.18.0",
    "@tiptap/extension-highlight": "^3.18.0",
    "@tiptap/extension-image": "^3.18.0",
    "@tiptap/extension-link": "^3.18.0",
    "@tiptap/extension-placeholder": "^3.18.0",
    "@tiptap/extension-subscript": "^3.18.0",
    "@tiptap/extension-superscript": "^3.18.0",
    "@tiptap/extension-table": "^3.18.0",
    "@tiptap/extension-task-item": "^3.18.0",
    "@tiptap/extension-task-list": "^3.18.0",
    "@tiptap/extension-text-align": "^3.18.0",
    "@tiptap/extension-text-style": "^3.18.0",
    "@tiptap/extension-underline": "^3.18.0",
    "@tiptap/pm": "^3.18.0",
    "@tiptap/react": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "@types/dompurify": "^3.2.0",
    "diff": "^8.0.3",
    "dompurify": "^3.3.3",
    "gitea-js": "1.23.0",
    "lucide-react": "^0.574.0",
    "react": "^19",
    "react-dom": "^19",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@playwright/test": "^1.54.2",
    "jsdom": "^29.0.1"
  }
}
