{
  "name": "bindersnap-editor-demo",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run clean && bun build ./apps/app/index.html --outdir=dist --target=browser --minify --splitting --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*' && cp dist/index.html dist/404.html",
    "clean": "rm -rf dist",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun run services/api/db/migrate.ts",
    "db:studio": "bunx drizzle-kit studio",
    "debug": "bun run debug:app",
    "debug:app": "bun --inspect --hot server.ts",
    "debug:api": "bun --inspect --hot services/api/server.ts",
    "dev": "bun run dev:app",
    "dev:app": "bun --hot server.ts",
    "dev:api": "bun --hot services/api/server.ts",
    "down": "docker compose down -v --remove-orphans",
    "format": "bunx prettier --write \"**/*.{js,ts,jsx,tsx,html,css,json,yml,yaml,md}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "format:check": "bunx prettier --check \"**/*.{js,ts,jsx,tsx,html,css,json,yml,yaml,md}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "generate:api": "bun run scripts/generate-gitea-api.ts",
    "lighthouse": "bun run build && sh -c 'python3 -m http.server 4173 --directory dist >/dev/null 2>&1 & SERVER_PID=$!; sleep 1; bunx lighthouse http://localhost:4173 --output=json --output-path=./lighthouse.json --quiet --chrome-flags=\"--headless --no-sandbox --disable-gpu\" --no-enable-error-reporting; kill $SERVER_PID' && bun run summarize",
    "serve": "bun run serve:app",
    "serve:app": "NODE_ENV=production bun server.ts",
    "serve:api": "NODE_ENV=production bun services/api/server.ts",
    "start": "bun run serve:app",
    "summarize": "bun scripts/summarize-lighthouse.ts",
    "test": "bun run test:all",
    "test:all": "bun run test:app && bun run test:ops",
    "test:app": "bun test apps/app packages/gitea-client packages/editor packages/utils",
    "test:ops": "bun test services/api scripts infra/backups",
    "test:integration": "bunx playwright test --config=playwright.config.ts",
    "test:unit": "bun test",
    "up": "docker compose up --build",
    "tf:apply": "bash infra/apply-all.sh",
    "tf:bootstrap": "bash infra/bootstrap.sh",
    "tf:plan": "bash infra/apply-all.sh plan",
    "version": "auto-changelog -p && git add CHANGELOG.md"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-subscript": "^3.22.4",
    "@tiptap/extension-superscript": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/dompurify": "^3.2.0",
    "auto-changelog": "^2.5.0",
    "diff": "^8.0.4",
    "dompurify": "^3.4.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.574.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3"
  }
}
