# Copy this file to .env and fill in values after first docker compose up.
# The seed script prints ALICE_TOKEN to stdout on first run.

VITE_GITEA_URL=http://localhost:3000
VITE_GITEA_TOKEN=
VITE_HOCUSPOCUS_URL=ws://localhost:1234
APP_PORT=5173
API_PORT=8787
BUN_PUBLIC_API_BASE_URL=http://localhost:8787
GITEA_INTERNAL_URL=http://gitea:3000
GITEA_ADMIN_USER=alice
GITEA_ADMIN_PASS=bindersnap-dev
BINDERSNAP_APP_ORIGIN=http://localhost:5173
BINDERSNAP_GITEA_TOKEN_SCOPES=read:repository

# OAuth2 PKCE app — filled in automatically by seed script output.
# Client type: Public (no secret required for PKCE).
BUN_PUBLIC_GITEA_OAUTH_CLIENT_ID=
BUN_PUBLIC_GITEA_OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# Pandoc conversion service
BUN_PUBLIC_PANDOC_SERVICE_URL=http://localhost:3001

# Stripe (required for subscription paywall)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from: stripe listen --forward-to localhost:8787/stripe/webhook --print-secret
STRIPE_PRICE_ID=price_...         # $100/month price ID from Stripe Dashboard
