# Railway Gitea Deployment — Environment Variables
# Copy these into your Railway service's "Variables" settings.
# Do NOT commit actual values to this file.

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allow the Bindersnap SPA to call Gitea directly from the browser.
GITEA__cors__ENABLED=true
GITEA__cors__ALLOW_DOMAIN=https://bindersnap.com
GITEA__cors__METHODS=GET,HEAD,POST,PUT,PATCH,DELETE,OPTIONS
GITEA__cors__ALLOW_CREDENTIALS=true

# ── Server ────────────────────────────────────────────────────────────────────
GITEA__server__DOMAIN=<your-railway-domain>.railway.app
GITEA__server__ROOT_URL=https://<your-railway-domain>.railway.app/

# ── Database (Railway managed Postgres) ──────────────────────────────────────
GITEA__database__DB_TYPE=postgres
GITEA__database__HOST=${{Postgres.PGHOST}}:${{Postgres.PGPORT}}
GITEA__database__NAME=${{Postgres.PGDATABASE}}
GITEA__database__USER=${{Postgres.PGUSER}}
GITEA__database__PASSWD=${{Postgres.PGPASSWORD}}
GITEA__database__SSL_MODE=require

# ── Security ──────────────────────────────────────────────────────────────────
GITEA__security__SECRET_KEY=<generate with: openssl rand -hex 32>
GITEA__security__INTERNAL_TOKEN=<generate with: openssl rand -hex 32>

# ── OAuth2 App ────────────────────────────────────────────────────────────────
# After deploying Gitea, register a Public OAuth2 app in Admin > Applications:
#   Name: bindersnap
#   Redirect URI: https://bindersnap.com/auth/callback
#   Client type: Public (required for PKCE — no client secret)
#
# Then copy the generated CLIENT_ID into your SPA build env:
#   VITE_GITEA_OAUTH_CLIENT_ID=<client_id from Gitea admin>
